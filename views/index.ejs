<%- include('partials/header') %>

<main style="background-color: #F7F8FA; padding: 20px 0; font-family: sans-serif;">
  <div style="width: 90%; margin: 0 auto; background: white; border: 1px solid #E3E8EE; border-radius: 8px; display: flex; align-items: stretch; padding: 15px; gap: 15px;">
    
    <aside style="width: 240px; flex-shrink: 0;">
      <ul style="list-style: none; padding: 0; margin: 0;">
        <li style="padding: 10px 15px; color: #505050; cursor: pointer;">Automobiles</li>
        <li style="padding: 10px 15px; color: #505050; cursor: pointer;">Clothes and wear</li>
        <li style="padding: 10px 15px; color: #505050; cursor: pointer;">Home interiors</li>
        <a href="/grid" style="text-decoration: none;">
            <li style="padding: 10px 15px; background: #E5F1FF; border-radius: 6px; font-weight: 500; color: #0D6EFD; cursor: pointer;">Computer and tech</li>
        </a>
        <li style="padding: 10px 15px; color: #505050; cursor: pointer;">Tools, equipments</li>
        <li style="padding: 10px 15px; color: #505050; cursor: pointer;">Sports and outdoor</li>
        <li style="padding: 10px 15px; color: #505050; cursor: pointer;">Animal and pets</li>
        <li style="padding: 10px 15px; color: #505050; cursor: pointer;">Machinery tools</li>
        <li style="padding: 10px 15px; color: #505050; cursor: pointer;">More category</li>
      </ul>
    </aside>

    <section style="flex-grow: 1; border-radius: 4px; overflow: hidden; background: #F3F3F3;">
      <img src="/banner.png" alt="Banner" style="width: 100%; height: 100%; display: block; object-fit: cover;">
    </section>

    <div style="width: 220px; display: flex; flex-direction: column; gap: 10px; flex-shrink: 0;">
      <div style="background: #E3F0FF; padding: 15px; border-radius: 6px; flex: 1; display: flex; flex-direction: column; justify-content: center;">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
          <img src="/Avatar.png" alt="User" style="width: 40px; height: 40px; border-radius: 50%; background: #ccc;">
          <span style="font-size: 14px; color: #1C1C1C;">Hi, user<br>let's get started</span>
        </div>
        <button style="width: 100%; background: #0D6EFD; color: white; border: none; padding: 8px; border-radius: 6px; margin-bottom: 8px; cursor: pointer; font-weight: 500;">Join now</button>
        <button style="width: 100%; background: white; color: #0D6EFD; border: 1px solid #E3E8EE; padding: 8px; border-radius: 6px; cursor: pointer; font-weight: 500;">Log in</button>
      </div>
      <div style="background: #F38332; padding: 15px; border-radius: 6px; color: white; font-size: 14px; flex: 1; display: flex; align-items: center;">
        Get US $10 off with a new supplier
      </div>
      <div style="background: #55BDC3; padding: 15px; border-radius: 6px; color: white; font-size: 14px; flex: 1; display: flex; align-items: center;">
        Send quotes with supplier preferences
      </div>
    </div>
  </div>
</main>

<section style="width: 90%; margin: 20px auto; background: white; border: 1px solid #E3E8EE; border-radius: 8px; display: flex; overflow: hidden; font-family: sans-serif;">
  <div style="width: 280px; padding: 20px; border-right: 1px solid #E3E8EE; flex-shrink: 0;">
    <h3 style="font-size: 20px; font-weight: 600; margin: 0; color: #1C1C1C;">Deals and offers</h3>
    <p style="color: #8B96A5; margin: 5px 0 20px;">Hygiene equipments</p>
    <div style="display: flex; gap: 6px;">
      <div style="background: #606060; color: white; width: 45px; height: 50px; border-radius: 4px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <span style="font-weight: 700;">04</span><span style="font-size: 10px;">Days</span>
      </div>
      <div style="background: #606060; color: white; width: 45px; height: 50px; border-radius: 4px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <span style="font-weight: 700;">13</span><span style="font-size: 10px;">Hour</span>
      </div>
      <div style="background: #606060; color: white; width: 45px; height: 50px; border-radius: 4px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <span style="font-weight: 700;">34</span><span style="font-size: 10px;">Min</span>
      </div>
      <div style="background: #606060; color: white; width: 45px; height: 50px; border-radius: 4px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <span style="font-weight: 700;">56</span><span style="font-size: 10px;">Sec</span>
      </div>
    </div>
  </div>
  <div style="display: flex; flex-grow: 1;">
    <% products.filter(p => p.category === "Deals").forEach(function(product) { %>
        <div onclick="window.location.href='/grid'" style="flex: 1; padding: 20px; text-align: center; border-right: 1px solid #E3E8EE; cursor: pointer;">
          <img src="<%= product.image %>" style="width: 130px; height: 130px; object-fit: contain; margin-bottom: 10px;" alt="<%= product.title %>">
          <p style="font-size: 14px; margin: 0 0 8px;"><%= product.title %></p>
          <span style="background: #FFE3E3; color: #EB001B; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;">
            -<%= product.discountPrice %>%
          </span>
        </div>
    <% }) %>
  </div>
</section>

<section style="width: 90%; margin: 20px auto; background: white; border: 1px solid #E3E8EE; border-radius: 8px; display: flex; overflow: hidden; font-family: sans-serif;">
  <div style="width: 280px; position: relative; flex-shrink: 0;">
    <img src="/outdoor.png" alt="Home and Outdoor" style="width: 100%; height: 100%; object-fit: cover; display: block;">
    <div style="position: absolute; top: 20px; left: 20px; width: 150px;">
      <h3 style="font-size: 20px; font-weight: 600; margin: 0; color: #1C1C1C; line-height: 1.3;">Home and outdoor</h3>
      <a href="/grid"><button style="margin-top: 15px; background: white; border: none; padding: 8px 16px; border-radius: 6px; font-weight: 500; cursor: pointer; color: #1C1C1C; box-shadow: 0px 1px 2px rgba(0,0,0,0.1);">Source now</button></a>
    </div>
  </div>
  <div style="display: grid; grid-template-columns: repeat(4, 1fr); flex-grow: 1;">
    <% products.filter(p => p.category === "HomeOutdoor").forEach(function(product) { %>
        <div onclick="window.location.href='/grid'" style="padding: 15px; border-right: 1px solid #E3E8EE; border-bottom: 1px solid #E3E8EE; display: flex; justify-content: space-between; cursor: pointer;">
          <div style="display: flex; flex-direction: column; justify-content: space-between;">
            <p style="font-size: 16px; margin: 0; color: #1C1C1C;"><%= product.title %></p>
            <span style="font-size: 13px; color: #8B96A5;">From <br> USD <%= product.price %></span>
          </div>
          <img src="<%= product.image %>" style="width: 65px; height: 65px; object-fit: contain;" alt="<%= product.title %>">
        </div>
    <% }) %>
  </div>
</section>

<section style="width: 90%; margin: 20px auto; background: white; border: 1px solid #E3E8EE; border-radius: 8px; display: flex; overflow: hidden; font-family: sans-serif;">
  <div style="width: 280px; position: relative; flex-shrink: 0;">
    <img src="/electronics-banner.png" alt="Consumer Electronics" style="width: 100%; height: 100%; object-fit: cover; display: block;">
    <div style="position: absolute; top: 20px; left: 20px; width: 180px;">
      <h3 style="font-size: 20px; font-weight: 600; margin: 0; color: #1C1C1C; line-height: 1.3;">Consumer electronics and gadgets</h3>
      <a href="/grid"><button style="margin-top: 15px; background: white; border: none; padding: 8px 16px; border-radius: 6px; font-weight: 500; cursor: pointer; color: #1C1C1C; box-shadow: 0px 1px 2px rgba(0,0,0,0.1);">Source now</button></a>
    </div>
  </div>
  <div style="display: grid; grid-template-columns: repeat(4, 1fr); flex-grow: 1;">
    <% products.filter(p => p.category === "Electronics").forEach(function(product) { %>
        <div onclick="window.location.href='/grid'" style="padding: 15px; border-right: 1px solid #E3E8EE; border-bottom: 1px solid #E3E8EE; display: flex; justify-content: space-between; cursor: pointer;">
          <div style="display: flex; flex-direction: column; justify-content: space-between;">
            <p style="font-size: 16px; margin: 0; color: #1C1C1C;"><%= product.title %></p>
            <span style="font-size: 13px; color: #8B96A5;">From <br> USD <%= product.price %></span>
          </div>
          <img src="<%= product.image %>" style="width: 65px; height: 65px; object-fit: contain;" alt="<%= product.title %>">
        </div>
    <% }) %>
  </div>
</section>

<section style="width: 90%; margin: 30px auto; height: 420px; border-radius: 8px; overflow: hidden; position: relative; font-family: sans-serif;">
  <img src="/inquiry-bg.png" alt="Inquiry Background" style="width: 100%; height: 100%; object-fit: cover; position: absolute; z-index: -1;">
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(90deg, #2C7CF1 0%, rgba(0, 209, 255, 0.5) 100%); z-index: 0;"></div>
  <div style="position: relative; z-index: 1; display: flex; padding: 40px; justify-content: space-between; align-items: flex-start;">
    <div style="width: 440px; color: white;">
      <h2 style="font-size: 32px; font-weight: 700; margin-bottom: 15px;">An easy way to send requests to all suppliers</h2>
      <p style="font-size: 16px; line-height: 1.5; opacity: 0.9;">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
    </div>
    <div style="background: white; padding: 25px; border-radius: 6px; width: 440px; box-shadow: 0px 4px 10px rgba(0,0,0,0.1);">
      <h3 style="font-size: 20px; font-weight: 600; margin: 0 0 20px; color: #1C1C1C;">Send quote to suppliers</h3>
      <form>
        <input type="text" placeholder="What item you need?" style="width: 100%; padding: 12px; border: 1px solid #E3E8EE; border-radius: 6px; margin-bottom: 15px; outline: none;">
        <textarea placeholder="Type more details" style="width: 100%; padding: 12px; border: 1px solid #E3E8EE; border-radius: 6px; margin-bottom: 15px; height: 80px; outline: none; resize: none;"></textarea>
        <div style="display: flex; gap: 10px; margin-bottom: 20px;">
          <input type="text" placeholder="Quantity" style="flex: 1; padding: 12px; border: 1px solid #E3E8EE; border-radius: 6px; outline: none;">
          <select style="width: 120px; padding: 12px; border: 1px solid #E3E8EE; border-radius: 6px; outline: none; background: white;">
            <option>Pcs</option><option>Kg</option>
          </select>
        </div>
        <button type="submit" style="background: #0D6EFD; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: 600; cursor: pointer;">Send inquiry</button>
      </form>
    </div>
  </div>
</section>

<section style="width: 90%; margin: 30px auto; font-family: sans-serif;">
  <h2 style="font-size: 24px; font-weight: 600; margin-bottom: 20px; color: #1C1C1C;">Recommended items</h2>
  <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px;">
    <% products.filter(p => p.category === "Recommended").forEach(function(product) { %>
      <div onclick="window.location.href='/grid'" style="background: white; border: 1px solid #E3E8EE; border-radius: 6px; padding: 15px; cursor: pointer;">
        <div style="height: 150px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">
          <img src="<%= product.image %>" style="max-width: 100%; max-height: 100%; object-fit: contain;" alt="<%= product.title %>">
        </div>
        <p style="font-weight: 600; font-size: 16px; margin: 0 0 5px; color: #1C1C1C;">$<%= product.price %></p>
        <p style="font-size: 14px; color: #8B96A5; line-height: 1.4; margin: 0;"><%= product.title %></p>
      </div>
    <% }) %>
  </div>
</section>

<%- include('partials/newsletter') %>
<%- include('partials/footer') %>