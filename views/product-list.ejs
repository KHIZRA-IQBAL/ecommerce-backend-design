<%- include('partials/header') %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<main style="background-color: #F7FAFC; padding: 20px 0; font-family: 'Inter', sans-serif;">
  <div style="width: 90%; margin: 0 auto;">
    
    <nav style="margin-bottom: 20px; color: #8B96A5; font-size: 16px;">
      Home <i class="fas fa-chevron-right" style="font-size: 12px; margin: 0 10px;"></i> 
      Electronics <i class="fas fa-chevron-right" style="font-size: 12px; margin: 0 10px;"></i> 
      Tech Gadgets <i class="fas fa-chevron-right" style="font-size: 12px; margin: 0 10px;"></i> 
      <span style="color: #1C1C1C;">Modern Tech</span>
    </nav>

    <div style="display: flex; gap: 28px;">
      
      <aside style="width: 240px; flex-shrink: 0;">
        <%- include('partials/filters-sidebar') %>
      </aside>

      <section style="flex-grow: 1;">
        <div style="background: white; border: 1px solid #E3E8EE; border-radius: 6px; padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
          <span style="font-size: 16px; color: #1C1C1C;">
            <strong style="font-weight: 600;"><%= products.length %></strong> items found in <strong style="font-weight: 600;">Electronics</strong>
          </span>
          <div style="display: flex; align-items: center; gap: 15px;">
            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 16px;">
              <input type="checkbox" checked style="width: 18px; height: 18px; accent-color: #0D6EFD;"> Verified only
            </label>
            <div style="display: flex; border: 1px solid #E3E8EE; border-radius: 6px; overflow: hidden; background: white;">
              <button style="padding: 10px 12px; background: white; border: none; border-right: 1px solid #E3E8EE; cursor: pointer;"><i class="fas fa-th-large"></i></button>
              <button style="padding: 10px 12px; background: #EFF2F4; border: none; cursor: pointer;"><i class="fas fa-bars"></i></button>
            </div>
          </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 10px;">
          <% products.forEach(function(item) { %>
            <div style="background: white; border: 1px solid #E3E8EE; border-radius: 6px; padding: 20px; display: flex; gap: 25px;">
              <div style="width: 210px; height: 210px; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                <img src="<%= item.image %>" style="max-width: 100%; max-height: 100%; object-fit: contain;" onerror="this.src='/tech/1.jpg'">
              </div>

              <div style="flex-grow: 1;">
                <div style="display: flex; justify-content: space-between;">
                  <h4 style="font-size: 18px; font-weight: 500; color: #1C1C1C; margin: 0;"><%= item.title %></h4>
                  <button style="background: white; border: 1px solid #E3E8EE; width: 40px; height: 40px; border-radius: 6px; color: #0D6EFD;"><i class="far fa-heart"></i></button>
                </div>
                
                <div style="margin: 10px 0;">
                  <span style="font-size: 20px; font-weight: 600;">$<%= item.price %></span>
                  <% if(item.discountPrice) { %>
                    <span style="color: #8B96A5; text-decoration: line-through; margin-left: 10px;">$<%= item.discountPrice %></span>
                  <% } %>
                </div>

                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
                  <div style="color: #FF9017;"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i> <span style="margin-left: 5px;">7.5</span></div>
                  <span style="color: #8B96A5;">• 154 orders •</span> 
                  <span style="color: #00B517; font-weight: 500;">Free Shipping</span>
                </div>

                <p style="color: #505050; line-height: 1.5; margin-bottom: 15px;"><%= item.description %></p>
                <a href="/product-detail?id=<%= item._id %>" style="color: #0D6EFD; text-decoration: none; font-weight: 500;">View details</a>
              </div>
            </div>
          <% }) %>
        </div>

        <div style="display: flex; justify-content: flex-end; align-items: center; gap: 10px; margin-top: 30px;">
          <select style="padding: 10px; border: 1px solid #E3E8EE; border-radius: 6px; background: white;"><option>Show 10</option></select>
          <div style="display: flex; border: 1px solid #E3E8EE; border-radius: 6px; overflow: hidden; background: white;">
              <button style="padding: 10px 15px; background: white; border: none; border-right: 1px solid #E3E8EE;"><i class="fas fa-chevron-left"></i></button>
              <button style="padding: 10px 15px; background: #EEEEEE; border: none; border-right: 1px solid #E3E8EE; font-weight: 600;">1</button>
              <button style="padding: 10px 15px; background: white; border: none;"><i class="fas fa-chevron-right"></i></button>
          </div>
        </div>
      </section>
    </div>
  </div>

  <div style="background-color: #EFF2F4; padding: 40px 0; margin-top: 40px; text-align: center;">
    <h3 style="font-size: 20px; font-weight: 600; color: #1C1C1C; margin-bottom: 5px;">Subscribe on our newsletter</h3>
    <p style="color: #606060; margin-bottom: 25px;">Get daily news on upcoming offers from many suppliers all over the world</p>
    <div style="display: flex; justify-content: center; gap: 8px;">
      <div style="position: relative; width: 300px;">
        <i class="far fa-envelope" style="position: absolute; left: 15px; top: 12px; color: #8B96A5;"></i>
        <input type="email" placeholder="Email" style="width: 100%; padding: 10px 10px 10px 40px; border: 1px solid #E3E8EE; border-radius: 6px;">
      </div>
      <button style="background: #0D6EFD; color: white; border: none; padding: 10px 20px; border-radius: 6px; font-weight: 500;">Subscribe</button>
    </div>
  </div>
</main>

<%- include('partials/footer') %>